    </CheatEntry>
    <CheatEntry>
      <ID>3</ID>
      <Description>"Lock gold through JS runtime"</Description>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript><![CDATA[[ENABLE]
{$lua}
if syntaxcheck then return end
