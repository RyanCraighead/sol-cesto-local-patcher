<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <AssemblyName>SolCestoPatcher</AssemblyName>
    <RootNamespace>SolCestoPatcher</RootNamespace>
    <Title>Sol Cesto Gold Patcher</Title>
    <FileDescription>Sol Cesto Gold Patcher</FileDescription>
    <Product>Sol Cesto Gold Patcher</Product>
    <Company>Craighead Labs</Company>
    <Authors>Craighead Labs</Authors>
    <Description>Gold patcher for Sol Cesto v100.2.</Description>
    <Copyright>Copyright (c) 2026 Craighead Labs</Copyright>
  </PropertyGroup>
</Project>
